; Engine configuration file.
;
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="AxonBIM"
config/description="Software BIM open-source hibrido Godot + Python."
run/main_scene="res://scenes/main/main.tscn"
; GL Compatibility por defecto: en Linux + NVIDIA (p. ej. RTX movil) + Flatpak,
; Forward+ (Vulkan) a veces provoca SIGABRT al cerrar o al iniciar. OpenGL es mas estable.
; Para Vulkan/Forward+ de nuevo: Project -> Project Settings -> Rendering -> Method.
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Logger="*res://scripts/autoload/logger.gd"
RpcClient="*res://scripts/autoload/rpc_client.gd"
EventBus="*res://scripts/autoload/event_bus.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/subwindows/embed_subwindows=false

[rendering]

renderer/rendering_method="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
